---
layout: base.njk
title: Home
---

<div class="landing">
  <div class="landing-hero">
    <div class="tagline landing-tagline">Made with love...and some other shit</div>
    <p class="landing-subtitle">Herbert family approved - straight from our kitchen to yours</p>
  </div>

  {% if collections.featured.length > 0 %}
  <div class="landing-section">
    <h2 class="landing-section-title">Family Favorites</h2>
    <div class="featured-grid">
      {%- for recipe in collections.featured -%}
      <a href="{{ recipe.url }}" class="featured-card" style="--card-accent: var(--accent-{{ ['pink','blue','purple'][recipe.data.recipeTags[0] | tagColorIndex] }})">
        {% if recipe.data.emoji %}<span class="featured-emoji">{{ recipe.data.emoji }}</span>{% endif %}
        <div class="featured-name">{{ recipe.data.name }}</div>
        {% if recipe.data.subtitle %}<div class="featured-subtitle">{{ recipe.data.subtitle }}</div>{% endif %}
        <div class="featured-tags">
          {%- for tag in recipe.data.recipeTags -%}
          <span class="tag" data-color="{{ tag | tagColorIndex }}">{{ tag }}</span>
          {%- endfor -%}
        </div>
      </a>
      {%- endfor -%}
    </div>
  </div>
  {% endif %}

  <div class="landing-cta">
    <a href="/recipes/" class="browse-all-btn">Browse all {{ collections.recipes.length }} recipes</a>
  </div>
</div>
